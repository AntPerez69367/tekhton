# Tekhton Conductor configuration
# For Docker: copy to $DOCKERDIR/appdata/tekhton-conductor/conductor.cfg
# Paths below are container-internal (matching volume mounts in compose YAML)

# Path to the tekhton repository (where tekhton.sh lives)
tekhton_path=/tekhton

# Path to the milestone manifest file
manifest_path=/repo/.claude/milestones/MANIFEST.cfg

# Path to the target project repository
repo_path=/repo

# Git integration branch for PRs
integration_branch=feature/Version3

# HTTP API port
api_port=7411

# Static bearer token for API authentication (also set CONDUCTOR_API_TOKEN in .env)
api_token=CHANGE_ME_TO_A_RANDOM_SECRET

# Anthropic API key (for error analysis calls — also set ANTHROPIC_API_KEY in .env)
anthropic_api_key=sk-ant-...

# Rolling usage window in hours
usage_window_hours=5

# Wait when remaining capacity drops below this fraction
usage_safety_threshold=0.25

# Stop after this many consecutive failures of the same milestone
max_milestone_retries=3

# Log file path (inside container — persisted via /data volume)
log_path=/data/logs/conductor.log

# Persistent state file path (inside container — persisted via /data volume)
state_path=/data/state/conductor.state.json
